# ============================================================
# StockTake Pro — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# Set these as Supabase secrets for Edge Functions:
#   supabase secrets set KEY="value"
# ============================================================

# Microsoft 365 SMTP — used by send-otp Edge Function
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=no-reply@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=StockTake Pro <no-reply@yourdomain.com>

# Power Automate webhook URLs (used by import Edge Functions)
PA_ITEMS_URL=https://prod-xx.westus.logic.azure.com/...
PA_BINS_URL=https://prod-xx.westus.logic.azure.com/...
PA_USERS_URL=https://prod-xx.westus.logic.azure.com/...

# Server security (fixes 1.3 + 1.4)
# Comma-separated list of allowed CORS origins for server.js
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000
# API key required on all requests to server.js (set any strong random string)
# Leave empty to disable the check (dev mode)
API_KEY=
